APP_NAME=Gapak API
APP_ENV=development
APP_BASE_URL=http://localhost:8080
APP_HOST=0.0.0.0
APP_PORT=8080
CORS_ORIGINS=http://localhost:3000

# Cloud PostgreSQL (Prisma Data Proxy) example:
# DATABASE_URL=postgres://user:password@db.prisma.io:5432/postgres?sslmode=require
#
# Local PostgreSQL example:
# DATABASE_URL=postgresql://postgres:5433@127.0.0.1:5432/gapak?sslmode=disable
# Previous example: postgresql://YOUR_USER:YOUR_PASSWORD@127.0.0.1:5432/gapak?sslmode=disable
#
# Docker Compose example:
# DATABASE_URL=postgresql://gapak:gapak@postgres:5432/gapak?sslmode=disable
DATABASE_URL=postgres://af38a65d8907ceaa55f2684a59e98269f14a6329dea2b3752fef1247f234aa6a:sk_zsDXsG7i2-7zMEMmZ-bvb@db.prisma.io:5432/postgres?sslmode=require
MIGRATIONS_DIR=db/migrations
DATABASE_MAX_OPEN_CONNS=20
DATABASE_MIN_OPEN_CONNS=5
DATABASE_MAX_CONN_LIFETIME=30m

REDIS_URL=redis://redis:6379/5

JWT_ISSUER=gapak.api
JWT_AUDIENCE=gapak.clients
JWT_ACCESS_SECRET=change-me-very-long-access-secret
JWT_REFRESH_SECRET=change-me-very-long-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
PASSWORD_PEPPER=change-me-pepper
ENCRYPTION_KEY_BASE64=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
REFRESH_COOKIE_NAME=gapak_rt
CSRF_COOKIE_NAME=gapak_csrf

ANONYMITY_ENABLED=true
ANONYMITY_REQUIRE_PSEUDONYMOUS_SIGNUP=true
ANONYMITY_ALLOW_ANONYMOUS_SIGNUP=true
ANONYMITY_ALLOW_EMAIL_SIGNUP=false
ANONYMITY_ALLOW_PASSWORD_RECOVERY=false
ANONYMITY_TRUST_PROXY_HEADERS=true
ANONYMITY_PROXY_HEADERS=CF-Connecting-IP,X-Forwarded-For,X-Real-IP
ANONYMITY_HASH_SECRET=change-me-anonymity-hash-secret-32
ANONYMITY_STORE_IP=false
ANONYMITY_STORE_USER_AGENT=false
ANONYMITY_STORE_DEVICE_FINGERPRINT=false
ANONYMITY_LOG_NETWORK_METADATA=false
ANONYMITY_EXPOSE_EMAIL_IN_RESPONSES=false

STORAGE_PROVIDER=s3
STORAGE_ENDPOINT=http://minio:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY_ID=gapak
STORAGE_SECRET_ACCESS_KEY=gapak-secret
STORAGE_BUCKET=gapak-private
STORAGE_PUBLIC_BASE_URL=https://storage.local
STORAGE_PROTECTED_BASE_URL=http://localhost:8080/media/protected
STORAGE_PUBLIC_CDN_BASE_URL=
STORAGE_PROTECTED_CDN_BASE_URL=
STORAGE_SIGNED_URL_TTL=15m
STORAGE_UPLOAD_INTENT_TTL=30m
STORAGE_PLAYBACK_GRANT_TTL=5m
STORAGE_SIGNING_SECRET=change-me-storage-signing-secret
STORAGE_MULTIPART_PART_SIZE_BYTES=8388608
STORAGE_MAX_UPLOAD_BYTES=26214400
STORAGE_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,video/mp4,application/pdf

QUEUE_MEDIA_PROCESSING=queue:media:processing
QUEUE_STORY_PROCESSING=queue:story:processing
QUEUE_LIVE_REPLAY=queue:live:replay
QUEUE_CLEANUP=queue:cleanup
QUEUE_LIVE_EVENTS=realtime:live-events
QUEUE_CLAIM_TTL=5m

WORKER_POLL_INTERVAL=2s
WORKER_BATCH_SIZE=10
WORKER_MEDIA_CONCURRENCY=4
STORY_DEFAULT_TTL=24h
LIVE_REPLAY_RETENTION=720h

RATE_LIMIT_GLOBAL_WINDOW=1m
RATE_LIMIT_GLOBAL_MAX=120
RATE_LIMIT_AUTH_WINDOW=5m
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_PASSWORD_WINDOW=15m
RATE_LIMIT_PASSWORD_MAX=5
